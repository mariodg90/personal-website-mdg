---
import { Image } from 'astro:assets';
import portrait from '../assets/mario-portrait.jpg';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = lang === 'it' ? '' : '/en';
---

<section class="container-page pt-16 md:pt-28 pb-20 md:pb-32">
  <div class="grid md:grid-cols-12 gap-10 md:gap-16 items-center">
    <div class="md:col-span-7 order-2 md:order-1">
      <p class="text-sm tracking-[0.18em] uppercase text-[color:var(--color-muted)] mb-6">
        {t('hero.eyebrow')}
      </p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[4.25rem] leading-[1.05] mb-8">
        {t('hero.headline')}
      </h1>
      <p class="text-lg md:text-xl text-[color:var(--color-muted)] max-w-2xl mb-10 leading-relaxed">
        {t('hero.lede')}
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a
          href={`${base}/#boosha`}
          class="inline-flex items-center gap-2 bg-[color:var(--color-fg)] text-[color:var(--color-bg)] px-6 py-3 rounded-full text-sm font-medium hover:opacity-85 transition-opacity"
        >
          {t('hero.cta.boosha')}
          <span aria-hidden="true">→</span>
        </a>
        <a
          href={`${base}/#contact`}
          class="inline-flex items-center gap-2 border border-[color:var(--color-line)] px-6 py-3 rounded-full text-sm font-medium hover:border-[color:var(--color-fg)] transition-colors"
        >
          {t('hero.cta.contact')}
        </a>
      </div>
    </div>
    <div class="md:col-span-5 order-1 md:order-2">
      <div class="relative aspect-[4/5] overflow-hidden rounded-sm">
        <Image
          src={portrait}
          alt={t('hero.portraitAlt')}
          widths={[400, 600, 900, 1200]}
          sizes="(min-width: 768px) 40vw, 80vw"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
