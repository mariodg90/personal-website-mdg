---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const expertise: Array<keyof typeof import('../i18n/ui').ui.it> = [
  'about.expertise.ai',
  'about.expertise.leadership',
  'about.expertise.strategy',
  'about.expertise.consulting',
];
---

<section id="about" class="container-page py-20 md:py-28 reveal">
  <div class="grid md:grid-cols-12 gap-10 md:gap-16">
    <div class="md:col-span-4">
      <p class="text-sm tracking-[0.18em] uppercase text-[color:var(--color-muted)] mb-4">
        {t('about.kicker')}
      </p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl leading-tight">
        {t('about.title')}
      </h2>
    </div>
    <div class="md:col-span-7 md:col-start-6 space-y-6 text-lg leading-relaxed text-[color:var(--color-fg)]/90">
      <p>{t('about.p1')}</p>
      <p>{t('about.p2')}</p>
      <p>{t('about.p3')}</p>

      <div class="pt-6 mt-6 hairline">
        <p class="text-sm tracking-[0.18em] uppercase text-[color:var(--color-muted)] mb-4">
          {t('about.expertise.title')}
        </p>
        <ul class="space-y-2 text-base">
          {expertise.map((key) => (
            <li class="flex items-start gap-3">
              <span class="mt-2 inline-block w-3 h-px bg-[color:var(--color-accent)]"></span>
              <span>{t(key)}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
