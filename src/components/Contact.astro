---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="container-page py-24 md:py-32 reveal">
  <div class="max-w-3xl">
    <p class="text-sm tracking-[0.18em] uppercase text-[color:var(--color-muted)] mb-4">
      {t('contact.kicker')}
    </p>
    <h2 class="text-4xl md:text-5xl lg:text-6xl leading-tight mb-8">
      {t('contact.title')}
    </h2>
    <p class="text-lg md:text-xl text-[color:var(--color-muted)] leading-relaxed mb-10 max-w-2xl">
      {t('contact.body')}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 sm:items-center">
      <a
        href={`mailto:${t('contact.email')}`}
        class="font-serif text-2xl md:text-3xl underline decoration-[color:var(--color-accent)]/40 hover:decoration-[color:var(--color-fg)] transition-colors"
      >
        {t('contact.email')}
      </a>
      <span class="hidden sm:inline text-[color:var(--color-muted)]">·</span>
      <a
        href="https://www.linkedin.com/in/digirolamomario/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-base text-[color:var(--color-muted)] hover:text-[color:var(--color-fg)] transition-colors inline-flex items-center gap-2"
      >
        {t('contact.linkedin')}
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</section>
